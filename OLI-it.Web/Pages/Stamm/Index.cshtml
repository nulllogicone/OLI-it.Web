@page "{id:guid}"
@model OLI_it.Web.Pages.Stamm.IndexModel
@{
    ViewData["Title"] = "Stamm";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }
    </div>

    @if (Model.Stamm != null)
    {
        var tabs = new List<(string Id, string Label, bool IsActive)>
        {
            ("postits", $"PostIts ({Model.StammPostIts?.Count ?? 0})", true),
            ("anglers", $"Anglers ({Model.StammAnglers?.Count ?? 0})", false),
            ("toplabs", $"TopLabs ({Model.StammTopLabs?.Count ?? 0})", false)
        };

        @await Html.PartialAsync("_TabsNavigation", tabs)

        <div id="postits" class="tab-content">
            <h3>PostIts (Messages)</h3>
            ViewData["StammGuid"] = Model.Stamm.StammGuid.ToString();
            @await Html.PartialAsync("_ChildPostItsTable", Model.StammPostIts ?? new List<OLI_it.Web.Models.Wurzeln>())
        </div>

        <div id="anglers" class="tab-content">
            <h3>Anglers (Filter Profiles)</h3>
            @await Html.PartialAsync("_ChildAnglersTable", Model.StammAnglers ?? new List<OLI_it.Web.Models.Angler>())
        </div>

        <div id="toplabs" class="tab-content">
            <h3>TopLabs (Answers Written)</h3>
            ViewData["Context"] = "stamm";
            @await Html.PartialAsync("_ChildTopLabsTable", Model.StammTopLabs ?? new List<OLI_it.Web.Models.TopLab>())
        </div>
    }
</div>

