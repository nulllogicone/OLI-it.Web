@page "~/stamm/{id:guid}/toplab"
@model OLI_it.Web.Pages.Stamm.TopLabModel
@{
    ViewData["Title"] = "TopLabs";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }
    </div>

    <div class="content-section">
        <h3>TopLabs (Answers Written)</h3>
        @if (Model.TopLabs.Any())
        {
            ViewData["Context"] = "stamm";
            @await Html.PartialAsync("_ChildTopLabsTable", Model.TopLabs)
        }
        else
        {
            <p class="no-data">No TopLab (answers) found for this Stamm.</p>
        }
    </div>
</div>
