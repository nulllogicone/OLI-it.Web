@page "~/stamm/{id:guid}/postit"
@model OLI_it.Web.Pages.Stamm.PostItModel
@{
    ViewData["Title"] = "PostIts";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }
    </div>

    <div class="content-section">
        <h3>PostIts (Messages)</h3>
        @if (Model.PostIts.Any())
        {
            ViewData["StammGuid"] = Model.Stamm?.StammGuid.ToString() ?? "";
            @await Html.PartialAsync("_ChildPostItsTable", Model.PostIts)
        }
        else
        {
            <p class="no-data">No PostIt messages found for this Stamm.</p>
        }
    </div>
</div>
