@page "~/stamm/{id:guid}/angler"
@model OLI_it.Web.Pages.Stamm.AnglerModel
@{
    ViewData["Title"] = "Angler (Filter Profiles)";
}

<div class="page-header">
    <h1>Angler (Filter Profiles)</h1>
    <p>Filter profiles for <strong>@Model.Stamm?.Stamm1</strong></p>
</div>

<div class="content-section">
    @if (Model.Anglers.Any())
    {
        <table class="simple-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Date Created</th>
                    <th>Scanned</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var angler in Model.Anglers)
                {
                    <tr>
                        <td>@angler.Angler1</td>
                        <td>@angler.Datum.ToString("yyyy-MM-dd")</td>
                        <td>@(angler.Gescannt ? "Yes" : "No")</td>
                        <td>@(angler.Beschreibung ?? "-")</td>
                        <td>
                            <a href="/angler/@angler.AnglerGuid">view</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="no-data">No Angler (filter profiles) found for this Stamm.</p>
    }
</div>
