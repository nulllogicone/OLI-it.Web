@page "~/stamm/{id:guid}/angler"
@model OLI_it.Web.Pages.Stamm.AnglerModel
@{
    ViewData["Title"] = "Anglers";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }
    </div>

    <div class="content-section">
        <h3>Anglers (Filter Profiles)</h3>
        @if (Model.Anglers.Any())
        {
            @await Html.PartialAsync("_ChildAnglersTable", Model.Anglers)
        }
        else
        {
            <p class="no-data">No Angler (filter profiles) found for this Stamm.</p>
        }
    </div>
</div>
