@using OLI_it.Web.Pages
@model NetzViewModel

@{
    int indentLevel = ViewData["IndentLevel"] as int? ?? 2;
}

<div class="tree-node netz-node nested-netz">
    <div class="tree-node-header" data-level="@indentLevel" data-auto-expand="true">
        @for (int i = 0; i < indentLevel; i++)
        {
            <span class="tree-indent"></span>
        }
        @if (Model.Knoten.Any())
        {
            <span class="tree-icon expand-icon">▼</span>
        }
        else
        {
            <span class="tree-icon no-expand">●</span>
        }
        <span class="tree-label netz-label">@Model.Name</span>
        @if (!string.IsNullOrEmpty(Model.Beschreibung))
        {
            <span class="tree-description">(@Model.Beschreibung)</span>
        }
    </div>
    @if (Model.Knoten.Any())
    {
        <div class="tree-children" style="display: block;">
            @foreach (var knoten in Model.Knoten)
            {
                <div class="tree-node knoten-node">
                    <div class="tree-node-header" data-level="@(indentLevel + 1)">
                        @for (int i = 0; i <= indentLevel; i++)
                        {
                            <span class="tree-indent"></span>
                        }
                        @if (knoten.Baum != null || knoten.WeiterNetz != null || knoten.WeiterNetzGuid.HasValue || knoten.WeiterBaumGuid.HasValue)
                        {
                            <span class="tree-icon expand-icon">▶</span>
                        }
                        else
                        {
                            <span class="tree-icon no-expand">●</span>
                        }
                        <span class="tree-connector">├</span>
                        <span class="tree-label knoten-label">@knoten.Name</span>
                        @if (!string.IsNullOrEmpty(knoten.Beschreibung))
                        {
                            <span class="tree-description">(@knoten.Beschreibung)</span>
                        }
                        @if (knoten.WeiterNetzGuid.HasValue)
                        {
                            <span class="tree-navigation">→ Netz</span>
                        }
                    </div>
                    @if (knoten.WeiterNetz != null)
                    {
                        <div class="tree-children" style="display: none;">
                            @{ ViewData["IndentLevel"] = indentLevel + 2; }
                            @await Html.PartialAsync("_NetzTreePartial", knoten.WeiterNetz)
                        </div>
                    }
                    else if (knoten.Baum != null)
                    {
                        <div class="tree-children" style="display: none;">
                            @{ ViewData["IndentLevel"] = indentLevel + 2; }
                            @await Html.PartialAsync("_BaumTreePartial", knoten.Baum)
                        </div>
                    }
                    else if (knoten.WeiterNetzGuid.HasValue || knoten.WeiterBaumGuid.HasValue)
                    {
                        @* Placeholder for on-demand loading *@
                        <div class="tree-children" 
                             style="display: none;" 
                             data-load-on-demand="true"
                             data-node-type="@(knoten.WeiterNetzGuid.HasValue ? "netz" : "baum")"
                             data-node-guid="@(knoten.WeiterNetzGuid ?? knoten.WeiterBaumGuid)"
                             data-indent-level="@(indentLevel + 2)">
                            <div class="loading-indicator">Loading...</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
