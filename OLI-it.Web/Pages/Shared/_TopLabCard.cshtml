@model OLI_it.Web.Models.TopLab

<div class="entity-card toplab-card">
    <div class="entity-card-header">
        <div class="header-left-content">
            @if (!string.IsNullOrEmpty(Model.Datei))
            {
                <div class="header-thumbnail">
                    @await Component.InvokeAsync("ImageThumbnail", new { dateiPath = Model.Datei, altText = $"TopLab {Model.Titel ?? "Untitled"} Image", width = 60, height = 60 })
                </div>
            }
            <h3>@(Model.Titel ?? "Untitled Answer")</h3>
        </div>
        <div class="card-meta-box">
            <div class="card-meta-datum">@Model.Datum.ToString("dd MMM yyyy")</div>
            <div class="card-meta-value">@Model.Lohn.ToString("N")</div>
        </div>
        <a href="/postit/@Model.PostItGuid" class="close-btn" title="Close to PostIt">&times;</a>
    </div>
    <div class="entity-card-body">
        <div class="entity-description">
            @Model.TopLab1
        </div>
        @if (!string.IsNullOrEmpty(Model.Url))
        {
            <div class="entity-link">
                <a href="@Model.Url" target="_blank">@Model.Url</a>
            </div>
        }
    </div>
</div>

