<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OLI-it</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var slotName = Environment.GetEnvironmentVariable("WEBSITE_SLOT_NAME");
    var isTestSlot = string.Equals(slotName, "test", StringComparison.OrdinalIgnoreCase);
    var isDevSlot = string.IsNullOrEmpty(slotName) && ViewContext.HttpContext.Request.Host.Host == "localhost";
}
<body class="@(isTestSlot ? "slot-test" : isDevSlot ? "slot-dev" : string.Empty)">
    @await Html.PartialAsync("_Header")

    <div class="app-container">
        <aside class="app-sidebar">
            @if (ViewData["Sidebar"] != null)
            {
                var sidebarName = ViewData["Sidebar"]?.ToString() ?? "_Sidebar";
                @await Html.PartialAsync(sidebarName, (object?)Model)
            }
            else
            {
                @await Html.PartialAsync("_Sidebar")
            }
        </aside>

        <main class="app-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/authentication.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
