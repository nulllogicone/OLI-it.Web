@model OLI_it.Web.Models.Stamm

<div class="entity-card stamm-card">
    <div class="entity-card-header">
        <div class="header-left-content">
            @if (!string.IsNullOrEmpty(Model.Datei))
            {
                <div class="header-thumbnail">
                    @await Component.InvokeAsync("ImageThumbnail", new { dateiPath = Model.Datei, altText = $"Stamm {Model.Stamm1} Image", width = 60, height = 60 })
                </div>
            }
            <h2>@Model.Stamm1</h2>
            @if (!string.IsNullOrEmpty(Model.Beschreibung))
            {
                <div class="entity-description">
                    @Model.Beschreibung
                </div>
            }
        </div>
        <div class="card-meta-box">
            <div class="card-meta-datum">@Model.Datum.ToString("dd MMM yyyy")</div>
            @if (Model.KooK.HasValue)
            {
                <div class="card-meta-value">@Model.KooK.Value.ToString("N")</div>
            }
        </div>
        <a href="/" class="close-btn" title="Close to Home">&times;</a>
    </div>

</div>
