@{
    var stammGuid = "";
    var postitGuid = "";
    var anglerGuid = "";
    var toplabGuid = "";
    var codeGuid = "";

    // Extract from query string or ViewData
    if (Context.Request.Query.ContainsKey("stamm"))
        stammGuid = Context.Request.Query["stamm"].ToString();
    if (Context.Request.Query.ContainsKey("postit"))
        postitGuid = Context.Request.Query["postit"].ToString();
    if (Context.Request.Query.ContainsKey("angler"))
        anglerGuid = Context.Request.Query["angler"].ToString();
    if (Context.Request.Query.ContainsKey("toplab"))
        toplabGuid = Context.Request.Query["toplab"].ToString();
    if (Context.Request.Query.ContainsKey("code"))
        codeGuid = Context.Request.Query["code"].ToString();
}

<nav class="sidebar-menu">
    <ul class="menu-list">
        <li class="menu-section-header">
            Entity Stack
        </li>

        @if (!string.IsNullOrEmpty(stammGuid))
        {
            <li class="menu-item @(string.IsNullOrEmpty(postitGuid) && string.IsNullOrEmpty(anglerGuid) && string.IsNullOrEmpty(toplabGuid) ? "active" : "")">
                <a href="/browse?stamm=@stammGuid">
                    📋 Stamm
                </a>
            </li>

            @if (!string.IsNullOrEmpty(postitGuid))
            {
                <li class="menu-item stack-child @(string.IsNullOrEmpty(codeGuid) && string.IsNullOrEmpty(toplabGuid) ? "active" : "")">
                    <a href="/browse?stamm=@stammGuid&postit=@postitGuid">
                        📝 PostIt
                    </a>
                </li>

                @if (!string.IsNullOrEmpty(codeGuid))
                {
                    <li class="menu-item stack-grandchild active">
                        <a href="/browse?stamm=@stammGuid&postit=@postitGuid&code=@codeGuid">
                            🔖 Code
                        </a>
                    </li>
                }

                @if (!string.IsNullOrEmpty(toplabGuid))
                {
                    <li class="menu-item stack-grandchild active">
                        <a href="/browse?stamm=@stammGuid&postit=@postitGuid&toplab=@toplabGuid">
                            💬 TopLab
                        </a>
                    </li>
                }
            }

            @if (!string.IsNullOrEmpty(anglerGuid))
            {
                <li class="menu-item stack-child active">
                    <a href="/browse?stamm=@stammGuid&angler=@anglerGuid">
                        🎣 Angler
                    </a>
                </li>
            }
        }
        else
        {
            <li class="menu-item-text">
                No entities selected
            </li>
        }

        @* Divider *@
        <li class="menu-divider"></li>

        @* General menu items *@
        <li class="menu-item">
            <a href="/">
                home
            </a>
        </li>
        <li class="menu-item">
            <a href="/browse">
                browse
            </a>
        </li>
        <li class="menu-item">
            <a href="/journal">
                timeline
            </a>
        </li>
    </ul>
</nav>
