@page "~/postit/{id:guid}/code"
@model OLI_it.Web.Pages.PostIt.CodeModel
@{
    ViewData["Title"] = "Codes";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }

        @if (Model.PostIt != null)
        {
            ViewData["StammGuid"] = Model.Stamm?.StammGuid.ToString() ?? "";
            @await Html.PartialAsync("_PostItCard", Model.PostIt)
        }
    </div>

    <div class="content-section">
        <h3>Codes (Descriptions)</h3>
        @if (Model.Codes.Any())
        {
            @await Html.PartialAsync("_ChildCodesTable", Model.Codes)
        }
        else
        {
            <p class="no-data">No Code (descriptions) found for this PostIt.</p>
        }
    </div>
</div>
