@page "~/postit/{id:guid}/toplab"
@model OLI_it.Web.Pages.PostIt.TopLabModel
@{
    ViewData["Title"] = "TopLabs";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }

        @if (Model.PostIt != null)
        {
            ViewData["StammGuid"] = Model.Stamm?.StammGuid.ToString() ?? "";
            @await Html.PartialAsync("_PostItCard", Model.PostIt)
        }
    </div>

    <div class="content-section">
        <h3>TopLabs (Answers)</h3>
        @if (Model.TopLabs.Any())
        {
            ViewData["Context"] = "postit";
            @await Html.PartialAsync("_ChildTopLabsTable", Model.TopLabs)
        }
        else
        {
            <p class="no-data">No TopLab (answers) found for this PostIt.</p>
        }
    </div>
</div>
