@page "{id:guid}"
@model OLI_it.Web.Pages.Angler.IndexModel
@{
    ViewData["Title"] = "Angler";
}

<div class="browse-container">
    <div class="entity-stack">
        @if (Model.Stamm != null)
        {
            @await Html.PartialAsync("_StammCard", Model.Stamm)
        }

        @if (Model.Angler != null)
        {
            @await Html.PartialAsync("_AnglerCard", Model.Angler)
        }
    </div>

    @if (Model.Angler != null)
    {
        var tabs = new List<(string Id, string Label, bool IsActive)>
        {
            ("catched", $"Catched PostIts ({Model.CatchedPostIts?.Count ?? 0})", true)
        };

        @await Html.PartialAsync("_TabsNavigation", tabs)

        <div id="catched" class="tab-content">
            <h3>Catched PostIts</h3>
            @await Html.PartialAsync("_ChildCatchedPostItsTable", Model.CatchedPostIts ?? new List<OLI_it.Web.Models.News>())
        </div>
    }
</div>

