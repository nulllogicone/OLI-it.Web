{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch OLI-it.Web (VS ports)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build web app",
      "program": "${workspaceFolder}/OLI-it.Web/bin/Debug/net10.0/OLI-it.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/OLI-it.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7119;http://localhost:5113"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
