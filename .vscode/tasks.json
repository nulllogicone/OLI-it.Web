{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build web app",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/OLI-it.Web/OLI-it.Web.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run web app (VS ports)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/OLI-it.Web/OLI-it.Web.csproj",
        "--launch-profile",
        "https"
      ],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
