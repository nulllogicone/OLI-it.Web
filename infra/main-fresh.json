{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "11107093829166859415"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "webAppName": {
      "type": "string"
    },
    "existingAppServicePlanResourceId": {
      "type": "string"
    },
    "existingLogAnalyticsWorkspaceResourceId": {
      "type": "string"
    },
    "existingKeyVaultResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "osType": {
      "type": "string",
      "defaultValue": "windows"
    },
    "linuxFxVersion": {
      "type": "string",
      "defaultValue": "DOTNETCORE|8.0"
    },
    "alwaysOn": {
      "type": "bool",
      "defaultValue": true
    },
    "tags": {
      "type": "object",
      "defaultValue": {}
    }
  },
  "variables": {
    "keyVaultSubscriptionId": "[if(not(empty(parameters('existingKeyVaultResourceId'))), split(parameters('existingKeyVaultResourceId'), '/')[2], '')]",
    "keyVaultResourceGroupName": "[if(not(empty(parameters('existingKeyVaultResourceId'))), split(parameters('existingKeyVaultResourceId'), '/')[4], '')]",
    "keyVaultName": "[if(not(empty(parameters('existingKeyVaultResourceId'))), split(parameters('existingKeyVaultResourceId'), '/')[8], '')]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('webApp-{0}', parameters('webAppName'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "webAppName": {
            "value": "[parameters('webAppName')]"
          },
          "appServicePlanResourceId": {
            "value": "[parameters('existingAppServicePlanResourceId')]"
          },
          "osType": {
            "value": "[parameters('osType')]"
          },
          "linuxFxVersion": {
            "value": "[parameters('linuxFxVersion')]"
          },
          "alwaysOn": {
            "value": "[parameters('alwaysOn')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "3348314100390802815"
            }
          },
          "parameters": {
            "location": {
              "type": "string"
            },
            "webAppName": {
              "type": "string"
            },
            "appServicePlanResourceId": {
              "type": "string"
            },
            "osType": {
              "type": "string",
              "defaultValue": "linux"
            },
            "linuxFxVersion": {
              "type": "string"
            },
            "alwaysOn": {
              "type": "bool",
              "defaultValue": true
            },
            "tags": {
              "type": "object",
              "defaultValue": {}
            }
          },
          "variables": {
            "isLinux": "[equals(toLower(parameters('osType')), 'linux')]",
            "siteConfig": "[union(createObject('alwaysOn', parameters('alwaysOn'), 'http20Enabled', true(), 'ftpsState', 'Disabled', 'minTlsVersion', '1.2'), if(variables('isLinux'), createObject('linuxFxVersion', parameters('linuxFxVersion')), createObject()))]"
          },
          "resources": [
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-12-01",
              "name": "[parameters('webAppName')]",
              "location": "[parameters('location')]",
              "kind": "[if(variables('isLinux'), 'app,linux', 'app')]",
              "tags": "[parameters('tags')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "serverFarmId": "[parameters('appServicePlanResourceId')]",
                "httpsOnly": true,
                "clientAffinityEnabled": false,
                "siteConfig": "[variables('siteConfig')]"
              }
            }
          ],
          "outputs": {
            "webAppResourceId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
            },
            "defaultHostName": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01').defaultHostName]"
            },
            "webAppIdentityPrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01', 'full').identity.principalId]"
            }
          }
        }
      }
    },
    {
      "condition": "[not(empty(parameters('existingKeyVaultResourceId')))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('kv-access-{0}', parameters('webAppName'))]",
      "subscriptionId": "[variables('keyVaultSubscriptionId')]",
      "resourceGroup": "[variables('keyVaultResourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "keyVaultName": {
            "value": "[variables('keyVaultName')]"
          },
          "tenantId": {
            "value": "[subscription().tenantId]"
          },
          "objectId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', format('webApp-{0}', parameters('webAppName'))), '2025-04-01').outputs.webAppIdentityPrincipalId.value]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "2367828256833361942"
            }
          },
          "parameters": {
            "keyVaultName": {
              "type": "string"
            },
            "tenantId": {
              "type": "string"
            },
            "objectId": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.KeyVault/vaults/accessPolicies",
              "apiVersion": "2023-07-01",
              "name": "[format('{0}/{1}', parameters('keyVaultName'), 'add')]",
              "properties": {
                "accessPolicies": [
                  {
                    "tenantId": "[parameters('tenantId')]",
                    "objectId": "[parameters('objectId')]",
                    "permissions": {
                      "secrets": [
                        "get",
                        "list"
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', format('webApp-{0}', parameters('webAppName')))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('diag-{0}', parameters('webAppName'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "targetWebAppName": {
            "value": "[parameters('webAppName')]"
          },
          "diagnosticSettingName": {
            "value": "[format('{0}-to-law', parameters('webAppName'))]"
          },
          "logAnalyticsWorkspaceResourceId": {
            "value": "[parameters('existingLogAnalyticsWorkspaceResourceId')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "317221074714805757"
            }
          },
          "parameters": {
            "targetWebAppName": {
              "type": "string"
            },
            "diagnosticSettingName": {
              "type": "string"
            },
            "logAnalyticsWorkspaceResourceId": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Insights/diagnosticSettings",
              "apiVersion": "2021-05-01-preview",
              "scope": "[resourceId('Microsoft.Web/sites', parameters('targetWebAppName'))]",
              "name": "[parameters('diagnosticSettingName')]",
              "properties": {
                "workspaceId": "[parameters('logAnalyticsWorkspaceResourceId')]",
                "logs": [
                  {
                    "categoryGroup": "allLogs",
                    "enabled": true
                  }
                ],
                "metrics": [
                  {
                    "category": "AllMetrics",
                    "enabled": true
                  }
                ]
              }
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "webAppResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('webApp-{0}', parameters('webAppName'))), '2025-04-01').outputs.webAppResourceId.value]"
    },
    "webAppDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('webApp-{0}', parameters('webAppName'))), '2025-04-01').outputs.defaultHostName.value]"
    }
  }
}